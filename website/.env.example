# Public site URL (canonical URLs, OG, sitemap, robots). Production: https://bloot.app
NEXT_PUBLIC_SITE_URL=https://bloot.app

# Resend (verification emails)
RESEND_API_KEY=

# Optional
RESEND_FROM_EMAIL=bloot <noreply@bloot.app>
# Replies go to support (verification + password-reset emails set Reply-To).
RESEND_REPLY_TO=support@bloot.app
# Light/white logo URL for HTML email header (default: NEXT_PUBLIC_SITE_URL + /assets/bloot.png).
# RESEND_EMAIL_LOGO_URL=https://bloot.app/assets/bloot.png

# bloot license Worker (Cloudflare). When set, login uses Worker; when BLOOT_INTERNAL_SECRET is also set, registration creates users + trial in D1.
BLOOT_API_URL=https://your-license-worker.workers.dev
BLOOT_INTERNAL_SECRET=replace-with-strong-random-secret


# Optional: raises GitHub API rate limit for /api/download/latest (public latest release .dmg / .exe)
GITHUB_TOKEN=

# Install tutorial embeds (full YouTube URL or 11-char video ID). Used by /[locale]/download/thanks/[os] and /download/thank-you.
NEXT_PUBLIC_VIDEO_INSTALL_MAC=https://www.youtube.com/watch?v=NdILBcMAB_o
NEXT_PUBLIC_VIDEO_INSTALL_WIN=https://www.youtube.com/watch?v=NdILBcMAB_o

# Session: no env needed (in-memory dev store). Production on Cloudflare: use encrypted cookies or KV later.
