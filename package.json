{
  "name": "qooti",
  "version": "0.1.3",
  "private": true,
  "description": "Local-first inspiration vault (Windows desktop app).",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run tauri dev",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "gen:icons": "node scripts/gen-icons.js",
    "pack": "npm run gen:icons && npm run tauri:build",
    "dist": "npm run gen:icons && npm run tauri:build",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.27.3",
    "png-to-ico": "^2.1.8",
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "@gutenye/ocr-browser": "^1.4.8",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.4",
    "cheerio": "^1.2.0",
    "cropperjs": "^1.6.2",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "html2canvas": "^1.4.1",
    "konva": "^9.3.18",
    "remixicon": "^4.9.1",
    "sharp": "^0.33.5",
    "sql.js": "^1.13.0",
    "uuid": "^10.0.0",
    "youtube-dl-exec": "^3.0.30"
  },
  "build": {
    "appId": "com.qooti.desktop",
    "productName": "qooti",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "src/**",
      "assets/**",
      "node_modules/**",
      "scripts/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    }
  }
}
